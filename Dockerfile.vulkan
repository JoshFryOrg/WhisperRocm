# Vulkan variant: builds whisper.cpp with the GGML Vulkan backend instead of HIP/ROCm.
# On AMD RDNA cards the HIP runtime pins the GPU to 100% utilisation for the whole
# life of the process (a ROCm bug, not whisper.cpp); the Vulkan backend via Mesa RADV
# does not, so the GPU idles properly even while the model is resident.
# Transcription speed can differ from the HIP build, so benchmark before adopting it.
FROM ubuntu:24.04

# Set non-interactive timezone to prevent tzdata from blocking the build.
ENV DEBIAN_FRONTEND=noninteractive

# Build deps + the Vulkan SDK pieces (loader headers and the glsl -> SPIR-V compiler
# the ggml shader generator needs), the runtime Vulkan loader + Mesa RADV driver, and
# ffmpeg for audio handling. No ROCm: RADV targets any RDNA GPU from SPIR-V at runtime,
# so there is no per-architecture build target to set.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    cmake \
    make \
    g++ \
    python3 \
    ca-certificates \
    ffmpeg \
    curl \
    libvulkan-dev \
    glslc \
    glslang-tools \
    libvulkan1 \
    mesa-vulkan-drivers \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone the whisper.cpp repository.
RUN git clone --depth=1 https://github.com/ggerganov/whisper.cpp.git .

# Configure and build with the Vulkan backend.
# GGML_VULKAN=ON is what selects the Vulkan compute path instead of HIP/CUDA/CPU.
RUN cmake -B build \
    -DGGML_VULKAN=ON \
    -DCMAKE_BUILD_TYPE=Release

# Build the binaries using all available CPU cores.
RUN cmake --build build -j $(nproc)

# Full large-v3 (~3 GB), the most accurate model of the family.
# The targeted AMD cards have the VRAM to keep it resident.
RUN bash ./models/download-ggml-model.sh large-v3

# Silero VAD model so VAD can drop non-speech, stopping the model
# hallucinating filler (e.g. "Thank you.") over silence/music.
RUN bash ./models/download-vad-model.sh silero-v5.1.2

# On-demand supervisor: fronts the server on the public port and only loads the
# model into VRAM while transcriptions are in flight, unloading it after an idle
# period so the GPU is free in between.
COPY supervisor.py /app/supervisor.py

# Expose the API port
EXPOSE 8080

# The supervisor binds the public 8080 and starts whisper-server on a private port
# on demand; pass the real server command (without --host/--port, which the
# supervisor appends) plus its flags.
# --inference-path serves the OpenAI route (default /inference); --vad + --vad-* enable VAD tuned to
# faster-whisper's default parameters (min-silence 2000, speech-pad 400, threshold 0.5).
ENTRYPOINT ["python3", "supervisor.py", "./build/bin/whisper-server", "-m", "models/ggml-large-v3.bin", "--inference-path", "/v1/audio/transcriptions", "--vad", "--vad-model", "models/ggml-silero-v5.1.2.bin", "--vad-threshold", "0.5", "--vad-min-speech-duration-ms", "0", "--vad-min-silence-duration-ms", "2000", "--vad-speech-pad-ms", "400"]
